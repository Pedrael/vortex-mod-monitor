{
  "name": "vortex-event-horizon",
  "version": "0.0.1",
  "description": "Vortex extension – Event Horizon: capture and reproduce a curator's exact mod state before Vortex's collection black hole loses it.",
  "type": "commonjs",
  "private": true,
  "scripts": {
    "build": "tsc",
    "build:vortex": "npm run build && npm run deploy:vortex",
    "deploy:vortex": "node scripts/deploy-to-vortex.js",
    "watch": "tsc -w",
    "typecheck": "tsc --noEmit",
    "gitnexus:setup": "bash scripts/gitnexus-setup.sh",
    "gitnexus:refresh": "gitnexus analyze --embeddings --skills",
    "gitnexus:full": "gitnexus analyze --force --embeddings --skills",
    "gitnexus:wiki": "gitnexus wiki",
    "gitnexus:wiki:review": "gitnexus wiki --review",
    "gitnexus:status": "gitnexus status",
    "gitnexus:list": "gitnexus list"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^16.14.69",
    "react": "^16.14.0",
    "typescript": "^5.7.0",
    "vortex-api": "github:Nexus-Mods/vortex-api"
  }
}
